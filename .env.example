# =============================================================================
# LARSSH Environment Variables
# Copy to `.env.local` and fill secrets from Supabase dashboard.
# =============================================================================

NEXT_PUBLIC_UI_ONLY=false
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=LARSSH

# Supabase Auth — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://vuwghcgmoyncvrlwpalj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Supabase PostgreSQL — Project Settings → Database → Connection string
#
# IMPORTANT — Next.js load order (later wins): .env → .env.local
# Keep DATABASE_URL and DIRECT_URL in .env.local only.
#
# DATABASE_URL  → Transaction pooler, port 6543, ?pgbouncer=true (app runtime)
# DIRECT_URL    → Direct DB host db.<ref>.supabase.co:5432 (migrate deploy only)
#
# Example (replace [password] with your database password):
# DATABASE_URL="postgresql://postgres.vuwghcgmoyncvrlwpalj:[password]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres:[password]@db.vuwghcgmoyncvrlwpalj.supabase.co:5432/postgres"
