{
  "name": "larssh",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "db:validate": "node --env-file=.env --env-file=.env.local ./node_modules/prisma/build/index.js validate",
    "db:generate": "node --env-file=.env --env-file=.env.local ./node_modules/prisma/build/index.js generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:seed:market": "tsx prisma/seed-market-intelligence.ts",
    "db:seed:roles": "node --env-file=.env --env-file=.env.local ./node_modules/tsx/dist/cli.mjs scripts/seed-roles.ts",
    "verify:env": "node --env-file=.env --env-file=.env.local ./node_modules/tsx/dist/cli.mjs scripts/verify-env.ts",
    "verify:db": "node --env-file=.env --env-file=.env.local ./node_modules/tsx/dist/cli.mjs scripts/verify-db-connection.ts",
    "db:studio": "prisma studio",
    "db:validate": "node --env-file=.env --env-file=.env.local ./node_modules/prisma/build/index.js validate",
    "profile:pages": "tsx scripts/profile-pages.ts",
    "benchmark:db": "tsx scripts/benchmark-db.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.50.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.513.0",
    "next": "^15.3.3",
    "papaparse": "^5.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.25.51"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^22.15.29",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "prisma": "^6.9.0",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
